# Token dari @BotFather (untuk bot @MatchInIdBot)
BOT_TOKEN=123456:ABC-your-bot-token

# Connection string dari Supabase (Project Settings -> Database -> Connection string -> URI)
# Contoh: postgresql://postgres:[PASSWORD]@db.xxxxxxxx.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:password@db.xxxxxxxx.supabase.co:5432/postgres

# ID grup Telegram tempat verifikasi video note & bukti bayar direview admin
# (angka negatif, contoh: -1001234567890)
ADMIN_GROUP_ID=-1001234567890

# User ID Telegram kamu (boleh lebih dari satu, pisahkan koma) supaya bisa pakai command admin
ADMIN_USER_IDS=123456789

# ---------- TRIPAY (payment gateway) ----------
# "sandbox" untuk testing (uang tidak asli), "production" untuk transaksi asli
TRIPAY_MODE=sandbox
# Ambil dari dashboard Tripay: https://tripay.co.id/member
TRIPAY_MERCHANT_CODE=T0001
TRIPAY_API_KEY=isi-api-key-kamu
TRIPAY_PRIVATE_KEY=isi-private-key-kamu

# Port HTTP untuk menerima webhook Tripay (Koyeb akan otomatis set PORT sendiri saat deploy
# sebagai Web Service, biasanya tidak perlu diisi manual)
PORT=8000

# URL publik bot kamu setelah dideploy, contoh: https://nama-app-kamu.koyeb.app
# WAJIB diisi supaya VIP bisa aktif OTOMATIS. Daftarkan juga
# {PUBLIC_BASE_URL}/tripay/callback sebagai "URL Callback" di dashboard Tripay (menu Merchant).
PUBLIC_BASE_URL=https://nama-app-kamu.koyeb.app
